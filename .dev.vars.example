# Copy to .dev.vars and set values. .dev.vars is gitignored.
# Required for local worker dev: SANITY_PROJECT_ID, SANITY_TOKEN

# --- Sanity ---
SANITY_PROJECT_ID=
SANITY_TOKEN=
# SANITY_API_TOKEN=   # alias for SANITY_TOKEN
SANITY_DATASET=production
SANITY_API_VERSION=2023-10-01
SANITY_WEBHOOK_SECRET=

# --- Worker URLs (wrangler [vars] override for local) ---
BASE_URL=http://localhost:8787
MOLT_TOOL_BASE_URL=
MOLTBOOK_BASE_URL=
# MOLTBOOK_NETWORK_URLS=    

# --- Wrangler bridge ---
WRANGLER_API_URL=
WRANGLER_API_KEY=

# --- Molt / API auth ---
MOLT_API_KEY=
# CHATGPT_API_KEY=

# --- Slack ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Gmail API ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Optional: appended to every sent/draft (use \n for newlines)
# GMAIL_SIGNATURE=
# Optional: From display name and address (recipients see "Austin @ Sanity" instead of raw email)
GMAIL_FROM_NAME=Austin @ Sanity
GMAIL_FROM_EMAIL=

# --- Admin ---
ADMIN_TOKEN=
ADMIN_API_KEY=

# --- LLM (enrichment, OSINT) ---
# LLM_PROVIDER=
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
# LLM_VISION_MODEL=
# LLM_TIMEOUT_MS=
# LLM_RETRIES=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Search (optional) ---
# BRAVE_SEARCH_API_KEY=
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=

# --- Crawl / OSINT ---
# CRAWL_ALLOWLIST=
# OSINT_DEFAULT_RECENCY_DAYS=
# OSINT_MAX_SOURCES=
# OSINT_MAX_EXTRACT=
# OSINT_YEAR=

# --- Moltbook POST protection ---
# MOLTBOOK_API_KEY=

# --- Metrics ---
# ANALYTICS_ENDPOINT=
# ENABLE_METRICS=
