# Sanity project used by the SDK app
VITE_SANITY_PROJECT_ID=nlqb7zmk
VITE_SANITY_DATASET=production

# Worker base URL used by the SDK app for research actions
# If you run the SDK inside Sanity's https shell, use an https worker URL or tunnel.
VITE_WORKER_URL=https://website-scanner.austin-gilbert.workers.dev

# Required if your worker protects snapshot / research routes
# Use the same value as MOLT_API_KEY from the worker env
VITE_WORKER_API_KEY=
