# Copy to .env for local SDK dev. Do not commit .env.

# Sanity project used by the SDK app
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Worker base URL for research actions (use https if running inside Sanity shell)
VITE_WORKER_URL=

# Must match the WORKER_API_KEY set in the Cloudflare Worker secrets
VITE_WORKER_API_KEY=
