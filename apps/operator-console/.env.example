# Wrangler API Configuration
# Copy this file to .env.local and update with your values

# Your Cloudflare Worker URL
# Example: https://your-worker.your-subdomain.workers.dev
NEXT_PUBLIC_API_URL=https://your-wrangler-worker.workers.dev

# Optional: API Key for authenticated requests (if your worker requires it)
# WRANGLER_API_KEY=your-api-key-here
