{
  "manifest_version": 3,
  "name": "Wrangler",
  "version": "4.0.0",
  "description": "Sales intelligence overlay — surfaces account insights, enrichment status, and research context on any page you browse.",
  "key": "MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.salesforce.com/*",
    "*://*.lightning.force.com/*",
    "*://*.outreach.io/*",
    "*://*.commonroom.io/*",
    "*://*.looker.com/*",
    "*://*.cloud.google.com/*",
    "*://*.hubspot.com/*",
    "*://*.gong.io/*",
    "*://*.apollo.io/*",
    "*://*.zoominfo.com/*",
    "*://*.6sense.com/*",
    "*://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Wrangler — Sales Intelligence",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  }
}
