{
  "manifest_version": 3,
  "name": "Rabbit",
  "version": "3.1.0",
  "description": "Always-on page awareness for LinkedIn, Salesforce, Outreach, Common Room, and the open web. Rabbit sees the page, surfaces opportunities, queues research, and lets you ask grounded questions in-context.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.salesforce.com/*",
    "*://*.lightning.force.com/*",
    "*://*.outreach.io/*",
    "*://*.commonroom.io/*",
    "*://*.looker.com/*",
    "*://*.cloud.google.com/*",
    "*://*.hubspot.com/*",
    "*://*.gong.io/*",
    "*://*.apollo.io/*",
    "*://*.zoominfo.com/*",
    "*://*.6sense.com/*",
    "*://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rabbit — AI Sales Super Eyes",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
