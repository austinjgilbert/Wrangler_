## Local dev + deployment secrets (copy to .env or .dev.vars)

# Worker base URL (local dev)
BASE_URL=http://localhost:8787

# Sanity (required)
SANITY_PROJECT_ID=
SANITY_TOKEN=
SANITY_DATASET=production
SANITY_API_VERSION=2023-10-01

# MoltBot tool gateway (set either base or per-tool)
MOLT_TOOL_BASE_URL=

# Optional per-tool overrides
# MOLT_RESEARCH_TOOL_URL=
# MOLT_GMAIL_TOOL_URL=
# MOLT_CALENDAR_TOOL_URL=
# MOLT_SLACK_TOOL_URL=
# MOLT_WEB_SEARCH_TOOL_URL=
# MOLT_SUMMARIZE_TOOL_URL=
# MOLT_MEMORY_SEARCH_TOOL_URL=
# MOLT_WHISPER_TOOL_URL=
# MOLT_GITHUB_TOOL_URL=
# MOLT_WRANGLER_TOOL_URL=

# Wrangler bridge (optional)
WRANGLER_API_URL=
WRANGLER_API_KEY=

# Slack (optional for DM/commands)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# Telegram bot (optional; for POST /webhooks/telegram)
# Create bot via @BotFather. Production: wrangler secret put TELEGRAM_BOT_TOKEN --env=production
# Webhook: see TELEGRAM-BOT-SETUP.md; full checklist: CHECKLIST-3-TELEGRAM-ENRICHMENT.md
TELEGRAM_BOT_TOKEN=

# Gmail API (optional; enables real Gmail read/draft/send)
# Required scopes typically include:
# - https://www.googleapis.com/auth/gmail.readonly
# - https://www.googleapis.com/auth/gmail.compose
# - https://www.googleapis.com/auth/gmail.send
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Admin protection (optional)
ADMIN_TOKEN=
ADMIN_API_KEY=
