# Worker local dev: copy to .dev.vars (see .dev.vars.example) and set values.
# Production: use `wrangler secret put VAR_NAME` (never commit .dev.vars or .env).

# --- Sanity ---
SANITY_PROJECT_ID=
SANITY_TOKEN=
SANITY_DATASET=production
SANITY_API_VERSION=2023-10-01
SANITY_WEBHOOK_SECRET=

# --- Worker URLs (local dev; production set in wrangler [vars]) ---
BASE_URL=http://localhost:8787
MOLT_TOOL_BASE_URL=
# MOLTBOOK_BASE_URL=
# MOLTBOOK_NETWORK_URLS=

# --- Wrangler bridge ---
WRANGLER_API_URL=
WRANGLER_API_KEY=

# --- Worker API auth ---
WORKER_API_KEY=
# Legacy aliases (still work): MOLT_API_KEY, CHATGPT_API_KEY
# MOLT_RESEARCH_TOOL_URL=
# MOLT_GMAIL_TOOL_URL=
# MOLT_CALENDAR_TOOL_URL=
