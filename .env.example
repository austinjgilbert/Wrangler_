# MOLT_MEMORY_SEARCH_TOOL_URL=
# MOLT_WHISPER_TOOL_URL=
# MOLT_GITHUB_TOOL_URL=
# MOLT_WRANGLER_TOOL_URL=

# --- Slack ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Gmail API ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Admin / API protection ---
ADMIN_TOKEN=
ADMIN_API_KEY=

